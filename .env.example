# Telegram bot
TELEGRAM_BOT_TOKEN=
# Optional login gate — nếu set, user phải /login <pwd> trước khi dùng bot
BOT_PASSWORD=

# Football-Data.org (free tier, ~10 req/min)
FOOTBALL_DATA_API_KEY=

# The Odds API (free: 500 req/month, paid: from $30/mo)
ODDS_API_KEY=

# API-Football / api-sports.io (MEGA: 150K req/day)
# Dùng cho live stats + INJURIES endpoint
API_FOOTBALL_KEY=

# OpenWeatherMap (free: 1M req/month)
# Dùng cho weather-based goal adjustment. Nếu trống → bot disable weather feature.
OPENWEATHER_API_KEY=

# DB URL (SQLite mặc định)
DATABASE_URL=sqlite:///football_analytics.db
